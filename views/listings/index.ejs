<% layout("layouts/boilerplate")%>

<style>
    #filters{
    display: flex;
    align-items: center;
    justify-content: space-between;
    overflow-x: auto;
    white-space: nowrap;
    padding: 1rem 0;
}
#filter-wrapper{
    display:flex;
    overflow:hidden;
    scroll-behavior:smooth;
    width:750px;
}

   .filter{
    text-align: center;
    margin-right: 5rem;
    margin-top: 2rem;
    opacity: 0.7;
    max-width: 90px;
    flex-shrink: 0;
    color:#fe424d;
    transition: transform 0.2s ease, opacity 0.2s ease;
}

.filter:hover{
    opacity: 1;
    cursor: pointer;
    transform: scale(1.15);
}

    .filter:hover{
        opacity: 1;
        cursor: pointer;
    }

    .filter p{
        font-size: 0.8rem;
    }

    .filter-link{
        text-decoration: none;
        color: #fe424d;
    }

    .filter-link:hover{
        color: #222222;
    }
    .tax-info{
        display: none;
    }
    .tax-toggle{
    border:1px solid black;
    border-radius:1rem;
    height:3.25rem;
    padding:1rem;
    display:flex;
    align-items:center;
    flex-shrink:0;
}
.arrow{
    font-size: 2.2rem;
    color: #fe424d;
    cursor: pointer;
    margin:0 0.5rem;
    font-weight:300;
}

.arrow:hover{
    opacity: 0.7;
}
.arrow.disabled{
    opacity:0.3;
    pointer-events:none;
    cursor: default;
}
.filter i{
    font-size: 1.2rem;
}
</style>

<div id="filters">
  <div class="arrow" id="left-btn">
       <i class="fa-solid fa-angle-left"></i>
    </div>

    <div id="filter-wrapper">

    <a href="/listings?category=Trending" class="filter-link">
        <div class="filter">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </div>
    </a>

    <a href="/listings?category=Room" class="filter-link">
        <div class="filter">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Room</p>
        </div>
    </a>

    <a href="/listings?category=Iconic Cities" class="filter-link">
        <div class="filter">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic Cities</p>
        </div>
    </a>

    <a href="/listings?category=Mountains" class="filter-link">
        <div class="filter">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </div>
    </a>

    <a href="/listings?category=Castels" class="filter-link">
        <div class="filter">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castels</p>
        </div>
    </a>

    <a href="/listings?category=Pools" class="filter-link">
        <div class="filter">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Pools</p>
        </div>
    </a>

    <a href="/listings?category=Camping" class="filter-link">
        <div class="filter">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </div>
    </a>

    <a href="/listings?category=Farms" class="filter-link">
        <div class="filter">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farms</p>
        </div>
    </a>

    <a href="/listings?category=Arctic" class="filter-link">
        <div class="filter">
            <div><i class="fa-regular fa-snowflake"></i></div>
            <p>Arctic</p>
        </div>
    </a>
     <a href="/listings?category=Domes" class="filter-link">
        <div class="filter">
            <div><i class="fa-solid fa-igloo"></i></div>
            <p>Domes</p>
        </div>
    </a>

    <a href="/listings?category=Boats" class="filter-link">
        <div class="filter">
            <div><i class="fa-solid fa-ship"></i></div>
            <p>Boats</p>
        </div>
    </a>
    </div>

<div class="arrow" id="right-btn">
    <i class="fa-solid fa-angle-right"></i>
</div>
<div class="tax-toggle">
    <div class="form-check-reverse form-switch">
  <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
  <label class="form-check-label" for="flexSwitchCheckDefault">Display taxes </label>
</div>
</div>
</div>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">

    <% if(allListings.length === 0){ %>

        <div class="text-center mt-5">
            <h3 style="color:#fe424d;">
                Sorry no Relevant Listings Found!!
            </h3>

            <p class="text-muted">
                EXPLORE AND FIND AWESOME LISTINGS AND DESTINATIONS
            </p>
        </div>

    <% } else { %>

        <% for(let listing of allListings){ %>

            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card col listing-card">

                    <img
                        src="<%= listing.image?.url %>"
                        class="card-img-top"
                        alt="listing_image"
                        style="height: 20rem"
                    />

                    <div class="card-img-overlay"></div>

                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b>
                            <br>
                            &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
                            <i class="tax-info">&nbsp; &nbsp;+18% GST </i>                        
                        </p>
                    </div>

                </div>
            </a>

        <% } %>

    <% } %>
</div>

<script>
const filterWrapper = document.getElementById("filter-wrapper");
const leftBtn = document.getElementById("left-btn");
const rightBtn = document.getElementById("right-btn");

function updateArrows() {

    if(filterWrapper.scrollLeft <= 0){
        leftBtn.classList.add("disabled");
    } else {
        leftBtn.classList.remove("disabled");
    }

    if(
        filterWrapper.scrollLeft + filterWrapper.clientWidth >=
        filterWrapper.scrollWidth - 5
    ){
        rightBtn.classList.add("disabled");
    } else {
        rightBtn.classList.remove("disabled");
    }
}

leftBtn.addEventListener("click", () => {
    filterWrapper.scrollBy({
        left:-150,
        behavior:"smooth"
    });

    setTimeout(updateArrows,300);
});

rightBtn.addEventListener("click", () => {
    filterWrapper.scrollBy({
        left:150,
        behavior:"smooth"
    });

    setTimeout(updateArrows,300);
});

updateArrows();
</script>

<script>
    let taxSwitch=document.getElementById("flexSwitchCheckDefault");
    taxSwitch.addEventListener("click",()=>{
        let taxInfo=document.getElementsByClassName("tax-info");
        for(info of taxInfo){
            if(info.style.display!="inline"){
                info.style.display="inline";
            }
            else{
                info.style.display="none";
            }
        }
        });
</script>